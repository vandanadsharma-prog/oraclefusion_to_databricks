# Backend configuration (optional)
#
# Copy to `.env` and edit if needed.

# If you keep passwords masked in the UI (YourStrongPassword), set the real one here:
# BACKEND_ORACLE_PASSWORD=YourPasswordHere

# Optional: if you keep Databricks tokens masked in the UI
# BACKEND_DATABRICKS_TOKEN=dapi...

# Optional: if you keep ADLS account keys masked in the UI
# BACKEND_ADLS_ACCESS_KEY=base64_account_key

# Optional: bearer token for REST API authType="bearer" (if masked in UI)
# BACKEND_REST_API_BEARER_TOKEN=...

# Where to save pipeline JSONs (default: "pipelines" relative to repo root)
# BACKEND_PIPELINES_DIR=pipelines
